		{
			"name": "Workouts",
			"item": [
				{
					"name": "Create Workout (nested)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.id) {",
									"    pm.collectionVariables.set('workout_id', res.id);",
									"}",
									"if (res.workout_exercises && res.workout_exercises.length > 0) {",
									"    pm.collectionVariables.set('we_id', res.workout_exercises[0].id);",
									"    if (res.workout_exercises[0].sets && res.workout_exercises[0].sets.length > 0) {",
									"        pm.collectionVariables.set('set_id', res.workout_exercises[0].sets[0].id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"workout_date\": \"2026-02-22\",\n    \"day\": 1,\n    \"title\": \"Push Day\",\n    \"notes\": \"Feeling strong\",\n    \"started_at\": null,\n    \"ended_at\": null,\n    \"duration_minutes\": null,\n    \"intensity\": 8,\n    \"calories_est_total\": null,\n    \"exercises\": [\n        {\n            \"exercise_id\": \"{{exercise_id}}\",\n            \"order_index\": 0,\n            \"notes\": \"Focus on form\",\n            \"sets\": [\n                { \"set_index\": 0, \"reps\": 10, \"weight\": 60, \"unit\": \"kg\", \"is_warmup\": true },\n                { \"set_index\": 1, \"reps\": 8, \"weight\": 70, \"unit\": \"kg\" },\n                { \"set_index\": 2, \"reps\": 6, \"weight\": 80, \"unit\": \"kg\", \"rpe\": 9 }\n            ]\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/workouts",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"workouts"
							]
						}
					}
				},
